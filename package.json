{
  "name": "tfg-horarios",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev:front": "cd frontend && bun run dev",
    "dev:back": "cd backend && bun run dev",
    "dev": "bun run dev:back & bun run dev:front",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f",
    "db:studio": "cd backend && bun run db:studio",
    "db:push": "cd backend && bun run db:push",
    "docs": "typedoc",
    "clean": "rm -rf node_modules frontend/node_modules backend/node_modules shared/node_modules frontend/.next backend/dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "bun-types": "^1.3.10",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.17",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}

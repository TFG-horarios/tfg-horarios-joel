{
  "name": "tfg-horarios",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev:front": "cd frontend && bun run dev",
    "dev:back": "cd backend && bun run dev",
    "dev": "concurrently \"bun run dev:back\" \"bun run dev:front\"",
    "test:backend": "cd backend && bun run test:coverage",
    "test:frontend": "cd frontend && bun run test:coverage",
    "test:ci": "npm run test:backend && npm run test:frontend",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:up": "cd backend && docker compose up -d",
    "db:down": "cd backend && docker compose down",
    "db:logs": "cd backend && docker compose logs -f",
    "db:studio": "cd backend && bun run db:studio",
    "db:push": "cd backend && bun run db:push",
    "docs": "typedoc",
    "clean": "rm -rf node_modules frontend/node_modules backend/node_modules shared/node_modules frontend/.next backend/dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "concurrently": "^9.0.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.17",
    "typescript-eslint": "^8.57.0",
    "typescript": "^5.9.3"
  }
}

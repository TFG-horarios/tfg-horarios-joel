{
  "name": "@tfg-horarios/backend",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=../coverage/backend",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.2",
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.10.3",
    "@tfg-horarios/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9"
  }
}
